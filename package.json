{
  "name": "allegro-ts-emscripten",
  "description": "Allegro 4 native code brought to the browser",
  "version": "1.0.0",
  "repository": "https://github.com/alegemaate/allegro-ts-emscripten",
  "author": "Allan Legemaate <alegemaate@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "yarn build:allegro-ts && yarn build:bindings",
    "build:allegro-ts": "esbuild ./node_modules/allegro-ts/dist/index.mjs --bundle --format=iife --global-name=lallegts --outfile=build/allegro-ts.js",
    "build:bindings": "esbuild src/allegrolib.ts --outfile=build/allegrolib.js --bundle --format=cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "prettier": "^3.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "allegro-ts": "^1.0.0-3"
  }
}
